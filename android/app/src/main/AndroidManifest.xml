<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:name=".PoulePartyApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="PouleParty"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PouleParty">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PouleParty.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".PouleFCMService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Foreground service used while a game is active so the Chicken / Hunter keeps
             receiving location updates even when the app is backgrounded. Required by
             Android 14+ whenever the app uses ACCESS_BACKGROUND_LOCATION. -->
        <service
            android:name=".service.LocationForegroundService"
            android:foregroundServiceType="location"
            android:exported="false"
            android:stopWithTask="true" />

        <!-- FCM default notification channel (used when the server does not specify one) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="game_events" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />
    </application>

</manifest>
