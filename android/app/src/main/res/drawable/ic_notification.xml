<?xml version="1.0" encoding="utf-8"?>
<!--
    AND-L2 (store-audit 2026-05-18) — monochrome status-bar notification
    icon. Android strips color from status-bar icons (only the alpha
    channel survives), so the previous `@mipmap/ic_launcher` (full-color
    PNG) rendered as a solid white square. This vector drawable is a
    stylized chicken silhouette built from white-on-transparent paths so
    Android's tinting pipeline produces a recognizable monochrome glyph
    everywhere (status bar, lock screen, notification shade).

    Used by AndroidManifest.xml meta-data
    `com.google.firebase.messaging.default_notification_icon`. The
    foreground-service notification (LocationForegroundService) renders
    in the persistent ongoing band where color is preserved, so it
    keeps using `@mipmap/ic_launcher` directly — no change there.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?android:attr/colorControlNormal">
    <!-- Body -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,7
                          C8.5,7 6,9.5 6,13
                          C6,16 7.5,18 9.5,19
                          L9.5,21
                          L11,21
                          L11,19.5
                          L13,19.5
                          L13,21
                          L14.5,21
                          L14.5,19
                          C16.5,18 18,16 18,13
                          C18,9.5 15.5,7 12,7 Z" />
    <!-- Comb (red crest stylized as triangle) -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M10.5,5
                          L11.5,3.5
                          L12.5,5
                          L13.5,3.5
                          L14,7
                          L10,7 Z" />
    <!-- Beak -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M17.5,11
                          L19.5,11.5
                          L17.5,12.5 Z" />
    <!-- Eye dot (cut-out via transparency simulation: smaller circle) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="@android:color/white"
        android:strokeWidth="0.8"
        android:pathData="M15,10.5 m-0.4,0 a0.4,0.4 0 1,0 0.8,0 a0.4,0.4 0 1,0 -0.8,0" />
</vector>
