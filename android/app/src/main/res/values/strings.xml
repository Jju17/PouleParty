    <!-- Game Rules -->
    <string name="how_to_play">How to play</string>
    <string name="game_modes">Game Modes</string>
    <string name="rule_one_chicken">One player is the Chicken, the others are Hunters.</string>
    <string name="rule_circular_zone">The game takes place in a circular zone on the map.</string>
    <string name="rule_zone_shrinks">The zone shrinks over time based on game settings.</string>
    <string name="rule_win_condition">Hunters win by finding the Chicken. The Chicken wins by surviving until the end!</string>
    <string name="mode_follow_desc">The Hunters see a circle that follows the Chicken\'s position in real time. The Chicken must run and hide!</string>
    <string name="mode_follow_detail1">Chicken sends its position to all Hunters</string>
    <string name="mode_follow_detail2">Hunters see the zone move with the Chicken</string>
    <string name="mode_follow_detail3">Chicken does NOT see the Hunters</string>
    <string name="mode_stay_desc">The zone stays fixed on the map and shrinks over time. Everyone must stay inside!</string>
    <string name="mode_stay_detail1">No position sharing between players</string>
    <string name="mode_stay_detail2">The zone is centered on the starting location</string>
    <string name="mode_stay_detail3">Strategy: stay hidden inside the shrinking zone</string>
    <string name="mode_mutual_desc">Like Follow the Chicken, but the Chicken can also see all Hunters on her map!</string>
    <string name="mode_mutual_detail1">Chicken sends its position to Hunters</string>
    <string name="mode_mutual_detail2">Hunters send their position to the Chicken</string>
    <string name="mode_mutual_detail3">Both sides can track each other in real time</string>
    <string name="setting_start_end_name">Start / End time</string>
    <string name="setting_start_end_desc">When the game starts and ends. The Chicken wins if the time runs out!</string>
    <string name="setting_radius_interval_desc">How often the zone shrinks (in minutes).</string>
    <string name="setting_radius_decline_desc">How many meters the zone shrinks each update.</string>
    <string name="setting_map_desc">Choose the starting location and initial radius of the zone.</string>

