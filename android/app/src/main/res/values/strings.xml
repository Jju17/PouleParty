    <string name="mode_follow_detail2">Hunters see the zone move but not where the Chicken is</string>
    <string name="mode_follow_detail3">The Chicken must stay inside the zone to survive</string>
    <string name="mode_stay_desc">The zone shrinks and drifts randomly around the starting point. Hunters must find the Chicken with no position clues!</string>
    <string name="mode_stay_detail1">No position sharing between players</string>
    <string name="mode_stay_detail2">The zone drifts toward the final zone point set by the creator</string>
    <string name="mode_stay_detail3">Strategy: search the moving zone to find the Chicken!</string>
