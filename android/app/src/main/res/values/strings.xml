    <!-- Onboarding -->
    <string name="welcome_title">Welcome to\nPouleParty!</string>
    <string name="welcome_subtitle">The ultimate hide-and-seek\npub crawl game</string>
    <string name="nominate_chicken">Nominate a Chicken</string>
    <string name="nominate_subtitle">Pick the Stag, the Birthday Girl, or whoever just really wants to be a Chicken.\n\nTheir job is to hide.</string>
    <string name="hunt_them_down">Hunt Them Down</string>
    <string name="hunt_subtitle">Split into squads. Use the map to track them.\n\nThe Chicken could be hiding in any pub or bar.</string>
    <string name="need_location">We Need Your Location</string>
    <string name="location_granted">You\'re all set! The game will track location even in the background.\n\nMaximum fun guaranteed!</string>
    <string name="location_partial">Almost there! The game needs to track the Chicken even when the app is in the background.\n\nPlease allow background location.</string>
    <string name="location_denied">Without it, the game can\'t work.\nNo location = no map = no fun.\n\nWe promise we only use it during the game!</string>
    <string name="always_allowed">Always allowed!</string>
    <string name="allow_always">Allow Always</string>
    <string name="allow_location_access">Allow Location Access</string>
    <string name="choose_nickname">Choose Your Nickname</string>
    <string name="nickname_subtitle">This is how other players\nwill see you in the game.</string>
    <string name="your_nickname">Your nickname</string>
    <string name="the_endgame">The Endgame</string>
    <string name="endgame_subtitle">Close in on the Chicken. Complete challenges for points. Unleash weapons.\n\nIt\'s Mario Kart rules — anything goes.</string>
