rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Games collection
    match /games/{gameId} {
      // Any authenticated user can read a game (needed to join via game code)
      allow read: if request.auth != null;

      // Any authenticated user can create a game (must include creatorId matching their uid)
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.status == 'waiting';

      // Any player can update hunterIds and winners (join game, submit winner)
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['hunterIds', 'winners'])
                    && request.resource.data.hunterIds.size() <= resource.data.numberOfPlayers
                    && request.resource.data.winners.size() <= resource.data.numberOfPlayers;

      // Any authenticated player can update power-up active effect fields
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['activeInvisibilityUntil', 'activeZoneFreezeUntil', 'activeRadarPingUntil', 'activeDecoyUntil', 'activeJammerUntil']);

      // Only the creator can update status, gameCode, or other game settings
      allow update: if request.auth != null
                    && resource.data.creatorId == request.auth.uid;

      // Only the creator can delete, and only while still waiting
      allow delete: if request.auth != null
                    && resource.data.creatorId == request.auth.uid
                    && resource.data.status == 'waiting';

      // Chicken locations subcollection (only the creator can write)
      match /chickenLocations/{docId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
                      && get(/databases/$(database)/documents/games/$(gameId)).data.creatorId == request.auth.uid
                      && request.resource.data.keys().hasAll(['location', 'timestamp']);
        allow delete: if false;
      }

      // Hunter locations subcollection
      match /hunterLocations/{visitorId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && visitorId == request.auth.uid
                      && request.resource.data.hunterId == request.auth.uid
                      && request.resource.data.keys().hasAll(['hunterId', 'location', 'timestamp']);
        allow update: if request.auth != null
                      && visitorId == request.auth.uid
                      && request.resource.data.hunterId == request.auth.uid
                      && request.resource.data.keys().hasAll(['hunterId', 'location', 'timestamp']);
        allow delete: if false;
      }

      // Power-ups subcollection
      match /powerUps/{powerUpId} {
        allow read: if request.auth != null;
        // Only the creator can spawn power-ups (merge-safe)
        allow create: if request.auth != null
                      && get(/databases/$(database)/documents/games/$(gameId)).data.creatorId == request.auth.uid;
        // Collection: only if not already collected, and collectedBy must match the user
        allow update: if request.auth != null
                      && (
                        // Collecting: set collectedBy to own UID (only if not already collected)
                        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['collectedBy'])
                         && request.resource.data.collectedBy == request.auth.uid)
                        ||
                        // Activating: set activatedAt/expiresAt (only by the collector)
                        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['activatedAt', 'expiresAt'])
                         && resource.data.collectedBy == request.auth.uid)
                      );
        allow delete: if false;
      }
    }

    // FCM tokens — each user can only read/write their own token document
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny access to everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
