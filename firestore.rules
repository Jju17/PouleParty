rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Games collection
    match /games/{gameId} {
      // Any authenticated user can read a game (needed to join via game code)
      allow read: if request.auth != null;

      // Any authenticated user can create a game (must include creatorId matching their uid).
      // PP-45 cap: standard parties are limited to 5 players client-side; the
      // admin-mode wizard (gated by the `jujurahier` code) flips
      // `isAdminCreation = true` to lift the cap up to 500. The flag itself
      // is client-trusted (obfuscation, not real auth — see PP-9).
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.status == 'waiting'
                    && request.resource.data.zone.radius > 0
                    && request.resource.data.zone.radius <= 50000
                    && request.resource.data.maxPlayers >= 2
                    && (
                      request.resource.data.maxPlayers <= 5
                      || (request.resource.data.get('isAdminCreation', false) == true
                          && request.resource.data.maxPlayers <= 500)
                    )
                    && request.resource.data.timing.start < request.resource.data.timing.end
                    && request.resource.data.timing.headStartMinutes >= 0
                    && request.resource.data.zone.shrinkIntervalMinutes >= 1
                    // GameMasters are only added by `joinAsGameMaster` (PP-70).
                    // Force the create payload's `gameMasterIds` to be empty so
                    // a malicious client can't pre-populate it.
                    && request.resource.data.get('gameMasterIds', []).size() == 0
                    // At creation the chicken must be the creator. The GM
                    // can re-designate from the "Désigner la poule" screen
                    // once hunters have registered (PP-26).
                    && request.resource.data.chickenId == request.resource.data.creatorId;

      // Any player can update hunterIds and winners (join game, submit
      // winner). PP-90 dropped the in-app "registration required +
      // deadline" gate — any authenticated user can join, even
      // mid-game. The chicken is still never in `hunterIds`: at
      // creation `chickenId == creatorId` (PP-26); a GM-led
      // re-designation runs through the dedicated update rule below
      // and pulls the newly-designated hunter out of `hunterIds`
      // atomically.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['hunterIds', 'winners'])
                    && request.resource.data.hunterIds.size() <= resource.data.maxPlayers
                    && request.resource.data.winners.size() <= resource.data.maxPlayers
                    && !request.resource.data.hunterIds.hasAny([resource.data.chickenId]);

      // Only game participants can update power-up active effect fields.
      // `gameMasterIds` is admin-SDK only — the chicken can't self-promote
      // a GM via this path (PP-23). `chickenId` is gated by a dedicated
      // rule below (PP-26).
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.creatorId
                        || request.auth.uid in resource.data.hunterIds)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['gameMasterIds', 'chickenId']);

      // GameMaster (or the creator as a fallback when no GM has joined
      // yet) re-designates the chicken before the game starts. Single
      // field, `status == waiting` only — once the game is `inProgress`
      // or `done`, the role is frozen. Used by the "Désigner la poule"
      // screen (PP-26). hunterIds may be edited in the same write so the
      // newly-designated hunter can be removed from the hunter pool.
      allow update: if request.auth != null
                    && resource.data.status == 'waiting'
                    && (request.auth.uid == resource.data.creatorId
                        || request.auth.uid in resource.data.get('gameMasterIds', []))
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['chickenId', 'hunterIds'])
                    && request.resource.data.chickenId is string
                    && request.resource.data.chickenId.size() > 0
                    && !request.resource.data.hunterIds.hasAny([request.resource.data.chickenId]);

      // Only the creator can update other game settings. `gameMasterIds`
      // is admin-SDK only — `joinAsGameMaster` (PP-70) is the only path
      // that mutates it. `chickenId` is gated by the dedicated PP-26
      // rule above.
      allow update: if request.auth != null
                    && resource.data.creatorId == request.auth.uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['gameMasterIds', 'chickenId']);

      // Only the creator can delete, and only while still in `waiting`.
      allow delete: if request.auth != null
                    && resource.data.creatorId == request.auth.uid
                    && resource.data.status == 'waiting';

      // Private namespace for fields a client must never read or write.
      // Currently used by `joinAsGameMaster` (PP-70) to store the
      // GameMaster password. Admin SDK bypasses these rules.
      match /private/{docId} {
        allow read, write: if false;
      }

      // Chicken locations subcollection. GameMasters (PP-23) read the
      // chicken's location regardless of `gameMode` — they need it for
      // the validator carte, even in `stayInTheZone` where hunters are
      // blind to it. Writes are gated by the dedicated `chickenId`
      // (PP-26): the chicken is the player designated by that field,
      // not necessarily the creator.
      match /chickenLocations/{docId} {
        allow read: if request.auth != null
                    && (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId
                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds
                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));
        allow create, update: if request.auth != null
                      && request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.chickenId
                      && request.resource.data.keys().hasAll(['location', 'timestamp']);
        allow delete: if false;
      }

      // Hunter locations subcollection. GameMasters read every hunter's
      // location for the validator carte; only the hunter themselves can
      // write their own doc.
      match /hunterLocations/{visitorId} {
        allow read: if request.auth != null
                    && (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId
                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds
                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));
        allow create: if request.auth != null
                      && visitorId == request.auth.uid
                      && request.resource.data.hunterId == request.auth.uid
                      && request.resource.data.keys().hasAll(['hunterId', 'location', 'timestamp'])
                      && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds;
        allow update: if request.auth != null
                      && visitorId == request.auth.uid
                      && request.resource.data.hunterId == request.auth.uid
                      && request.resource.data.keys().hasAll(['hunterId', 'location', 'timestamp'])
                      && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds;
        allow delete: if false;
      }

      // Registrations subcollection. PP-90 dropped the in-app
      // registration-required gate, but the subcollection is still
      // written: each in-app hunter creates a doc keyed by their UID
      // so the GameMaster can pick a chicken from the team-name list
      // (PP-86). PP-52 will reuse this subcollection for external
      // Typeform/Stripe registrations using a random `registrationId`
      // instead of `userId`.
      match /registrations/{visitorId} {
        // Readable by the registration owner, the chicken creator,
        // and any GameMaster on the game. The GM needs every doc so
        // the validator carte can label markers + the "Désigner la
        // poule" drawer (PP-86) can list candidates.
        allow read: if request.auth != null
                    && (visitorId == request.auth.uid
                        || get(/databases/$(database)/documents/games/$(gameId)).data.creatorId == request.auth.uid
                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));
        allow create: if request.auth != null
                      && visitorId == request.auth.uid
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.keys().hasAll(['userId', 'teamName', 'joinedAt'])
                      && request.resource.data.teamName is string
                      && request.resource.data.teamName.size() > 0;
        allow update: if request.auth != null
                      && visitorId == request.auth.uid
                      && request.resource.data.userId == request.auth.uid;
        allow delete: if false;
      }

      // Challenge completions subcollection — one doc per hunter who has
      // completed at least one challenge. Readable by any participant (for
      // the live leaderboard). Writable only by the owning hunter, and only
      // while they are still in hunterIds.
      //
      // PP-36 (out-of-zone penalty): the same write path is reused by the
      // hunter to decrement their own `totalPoints` by 1 every 5 s while
      // outside the zone. The `hunterId == request.auth.uid` clause is the
      // load-bearing guarantee — no hunter can decrement (or increment)
      // another hunter's points. PP-25 will later flip the increment side
      // to validator (chicken / GM) writes; the decrement stays self-write.
      match /challengeCompletions/{hunterId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds;
        allow create, update: if request.auth != null
                      && request.auth.uid == hunterId
                      && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds;
        allow delete: if false;
      }

      // Power-ups subcollection
      match /powerUps/{powerUpId} {
        allow read: if request.auth != null
                    && (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId
                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds);
        // Power-ups are spawned exclusively by the `spawnPowerUpBatch` /
        // `onGameCreated` Cloud Functions (admin SDK bypasses rules). Clients
        // never create power-ups — prevents anti-cheat gaps and drift between
        // chicken app state and Firestore.
        allow create: if false;
        // Collection: only if not already collected, and collectedBy must match the user
        allow update: if request.auth != null
                      && (
                        // Collecting: set collectedBy + collectedAt (only if not already collected)
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collectedBy', 'collectedAt'])
                         && request.resource.data.collectedBy == request.auth.uid
                         && resource.data.get('collectedBy', null) == null)
                        ||
                        // Activating: set activatedAt/expiresAt (only by the collector)
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activatedAt', 'expiresAt'])
                         && resource.data.get('collectedBy', null) == request.auth.uid)
                      );
        allow delete: if false;
      }
    }

    // User profiles (nickname, FCM token, platform) — each user can only read/write their own document.
    match /users/{userId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Global challenges catalog — populated by devs via the Firebase Console.
    // Authenticated clients can read; no client writes.
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // GameMaster rate-limit counters (PP-70). One doc per
    // `{userId}_{gameId}` key, written exclusively by the
    // `joinAsGameMaster` Cloud Function via admin SDK. Clients can
    // neither read (no probing the lock) nor write (no resetting their
    // own counter).
    match /gmRateLimits/{docId} {
      allow read, write: if false;
    }

    // Event registrations (PP-52) — pre-paid registrations created from the
    // public web form before any in-app Game exists. Top-level collection
    // (deliberately separate from the per-game `/games/{gameId}/registrations`
    // subcollection used by PP-90/PP-86 for in-app teamName + chicken
    // designation). Each doc carries a `batchId` field; the admin-mode wizard
    // sets `Game.registrationBatchId` to the same value to link a game to
    // its batch.
    //
    // Writes are admin-SDK only: `createPendingRegistration` writes the doc
    // with `paid: false`, the Stripe webhook `confirmRegistrationPayment`
    // flips `paid: true` (both bypass these rules via admin SDK).
    //
    // Reads are open to any authenticated user. The validation code is the
    // load-bearing gate — JoinFlow queries `where batchId == X && code == Y
    // && paid == true`, and the 36^6 entropy of the 6-char alphanum code
    // makes brute-force impractical for the ~50 valid codes per batch.
    match /eventRegistrations/{registrationId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Player reports — created by authenticated users from the in-app "Report player"
    // button on leaderboards. Reads and mutations are admin-SDK-only so reporters can't
    // see each other's reports and reportees can't delete reports about them.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.reportedUserId is string
                    && request.resource.data.reportedUserId.size() > 0
                    && request.resource.data.reportedUserId != request.auth.uid
                    && request.resource.data.keys().hasAll(['reporterId', 'reportedUserId', 'reportedNickname', 'gameId', 'createdAt']);
      allow read, update, delete: if false;
    }

    // Deny access to everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
