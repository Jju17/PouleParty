rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /gameSubmissions/{gameId}/{file} {
      allow read: if request.auth != null
                  && (request.auth.uid == firestore.get(/databases/(default)/documents/games/$(gameId)).data.creatorId
                      || request.auth.uid in firestore.get(/databases/(default)/documents/games/$(gameId)).data.hunterIds
                      || request.auth.uid in firestore.get(/databases/(default)/documents/games/$(gameId)).data.get('gameMasterIds', []));
      allow write: if request.auth != null
                   && request.auth.uid in firestore.get(/databases/(default)/documents/games/$(gameId)).data.hunterIds
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
