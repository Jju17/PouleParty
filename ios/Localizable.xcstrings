      }
    },
    "Your nickname cannot be empty.": {
      "comment": "An alert message displayed when a user attempts to set an empty nickname.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton pseudo ne peut pas être vide."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je bijnaam mag niet leeg zijn."
          }
        }
      }
    },
    "YOUR VALIDATION CODE": {
      "comment": "PP-52: label above the prominent validation code on the deeplink fallback view.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "TON CODE DE VALIDATION"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "JE VALIDATIECODE"
          }
        }
      }
    },
    "Your validation code is saved. The party hasn't been set up yet — come back on June 6 with the game code we'll announce on site!": {
      "comment": "PP-52: body of the gameNotYetReady deeplink fallback.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton code de validation est sauvegardé. La partie n'est pas encore configurée — reviens le 6 juin avec le code de partie qu'on t'annoncera sur place !"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je validatiecode is opgeslagen. Het feest is nog niet ingericht — kom op 6 juni terug met de spelcode die we ter plaatse aankondigen!"
          }
        }
      }
    },
    "Enable GameMaster role": {
      "comment": "Title of the GameMaster password setup section in the game-creation wizard.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activer le rôle GameMaster"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "GameMaster-rol activeren"
          }
        }
      }
    },
    "Designate %@": {
      "comment": "Button label to designate a specific player as the chicken. %@ is the player's team name.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désigner %@"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ aanwijzen"
          }
        }
      }
    },
    "Designate as chicken": {
      "comment": "Button label inside the GameMaster's hunter row to make that hunter the chicken.",
      "localizations": {
        "fr": {
