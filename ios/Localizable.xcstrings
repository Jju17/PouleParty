    "Almost there! The game needs to track the Chicken even when the app is in the background.\n\nPlease select 'Always' on the next screen.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Almost there! The game needs to track the Chicken even when the app is in the background.\n\nPlease select 'Always' on the next screen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On y est presque ! Le jeu doit suivre la Poule même quand l'app est en arrière-plan.\n\nSélectionne 'Toujours' à l'écran suivant."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bijna klaar! Het spel moet de Kip volgen, ook als de app op de achtergrond draait.\n\nSelecteer 'Altijd' op het volgende scherm."
          }
        }
      }
    },
