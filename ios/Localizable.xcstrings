    "Get notified when the game starts, the zone shrinks, and when a hunter finds the chicken!\n\nThis is optional but recommended." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reçois une notification quand la partie commence, quand la zone rétrécit et quand un chasseur trouve la poule !\n\nC'est optionnel mais recommandé."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ontvang een melding wanneer het spel begint, de zone krimpt en wanneer een jager de kip vindt!\n\nDit is optioneel maar aanbevolen."
          }
        }
      }
    },
