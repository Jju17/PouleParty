<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>$(APS_ENVIRONMENT)</string>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:pouleparty.be</string>
		<!-- XPLAT-M3 (store-audit 2026-05-18): staging hostname so the
		     Universal Link flow can be QA'd against the staging Firebase
		     project before flipping production. The AASA file at
		     `pouleparty-ba586.web.app/.well-known/apple-app-site-association`
		     is shipped by the same `firebase deploy --only hosting` runs. -->
		<string>applinks:pouleparty-ba586.web.app</string>
	</array>
	<!-- iOS-H4 (store-audit 2026-05-18): App Attest. The Firebase
	     App Check `AppAttestProvider` requires this entitlement to be
	     present and resolved to either "development" (DEBUG builds) or
	     "production" (release builds). Without it, App Attest fails
	     silently on every release device once server-side
	     `enforceAppCheck` is flipped on. The value is driven by the
	     `APPATTEST_ENVIRONMENT` build setting injected per config. -->
	<key>com.apple.developer.devicecheck.appattest-environment</key>
	<string>$(APPATTEST_ENVIRONMENT)</string>
</dict>
</plist>

