{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.DS_Store", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=(), payment=()" },
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://*.cloudfunctions.net https://*.run.app https://api.stripe.com; frame-ancestors 'none'; form-action 'self' https://checkout.stripe.com; base-uri 'self'" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/createPendingRegistration",
        "function": {
          "functionId": "createPendingRegistration",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/processAccountDeletion",
        "function": {
          "functionId": "processAccountDeletion",
          "region": "europe-west1"
        }
      },
      {
        "source": "/challenges-fr",
        "function": {
          "functionId": "renderChallengesSheet",
          "region": "europe-west1"
        }
      },
      {
        "source": "/challenges-en",
        "function": {
          "functionId": "renderChallengesSheet",
          "region": "europe-west1"
        }
      },
      {
        "source": "/challenges-nl",
        "function": {
          "functionId": "renderChallengesSheet",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  }
}
