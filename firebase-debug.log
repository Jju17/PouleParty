[debug] [2026-05-30T14:02:22.688Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/pouleparty-prod/rulesets {"name":"projects/pouleparty-prod/rulesets/c566a65c-f082-492f-b210-33bf8b9d8b57","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Games collection\n    match /games/{gameId} {\n      // Any authenticated user can read a game (needed to join via game code)\n      allow read: if request.auth != null;\n\n      // Any authenticated user can create a game (must include creatorId matching their uid).\n      // PP-45 cap: standard parties are limited to 5 players client-side; the\n      // admin-mode wizard (gated by the `jujurahier` code) flips\n      // `isAdminCreation = true` to lift the cap up to 500. The flag itself\n      // is client-trusted (obfuscation, not real auth — see PP-9).\n      allow create: if request.auth != null\n                    && request.resource.data.creatorId == request.auth.uid\n                    && request.resource.data.status == 'waiting'\n                    && request.resource.data.zone.radius > 0\n                    && request.resource.data.zone.radius <= 50000\n                    && request.resource.data.maxPlayers >= 2\n                    && (\n                      request.resource.data.maxPlayers <= 5\n                      || (request.resource.data.get('isAdminCreation', false) == true\n                          && request.resource.data.maxPlayers <= 500)\n                    )\n                    && request.resource.data.timing.start < request.resource.data.timing.end\n                    && request.resource.data.timing.headStartMinutes >= 0\n                    && request.resource.data.zone.shrinkIntervalMinutes >= 1\n                    // GameMasters are only added by `joinAsGameMaster` (PP-70).\n                    // Force the create payload's `gameMasterIds` to be empty so\n                    // a malicious client can't pre-populate it.\n                    && request.resource.data.get('gameMasterIds', []).size() == 0\n                    // At creation the chicken must be the creator. The GM\n                    // can re-designate from the \"Désigner la poule\" screen\n                    // once hunters have registered (PP-26).\n                    && request.resource.data.chickenId == request.resource.data.creatorId;\n\n      // hunterIds-only update (join / leave a game). PP-90 dropped the\n      // in-app \"registration required + deadline\" gate — any\n      // authenticated user can join, even mid-game. The chicken is\n      // still never in `hunterIds`: at creation `chickenId == creatorId`\n      // (PP-26); a GM-led re-designation runs through the dedicated\n      // update rule below and pulls the newly-designated hunter out\n      // of `hunterIds` atomically.\n      //\n      // CRIT-3 (audit 2026-05-17): tightened so a caller can only\n      // add/remove their OWN UID. Previously any auth user could\n      // impersonate someone else into hunterIds, or saturate the\n      // array up to maxPlayers and lock real players out.\n      // `removeAll(other).hasOnly([uid])` enforces caller-only on\n      // both directions: additions = hunterIds_new \\ hunterIds_old,\n      // removals = hunterIds_old \\ hunterIds_new.\n      allow update: if request.auth != null\n                    && request.resource.data.diff(resource.data).affectedKeys()\n                        .hasOnly(['hunterIds'])\n                    && request.resource.data.hunterIds.size() <= resource.data.maxPlayers\n                    && !request.resource.data.hunterIds.hasAny([resource.data.chickenId])\n                    && request.resource.data.hunterIds\n                        .removeAll(resource.data.hunterIds)\n                        .hasOnly([request.auth.uid])\n                    && resource.data.hunterIds\n                        .removeAll(request.resource.data.hunterIds)\n                        .hasOnly([request.auth.uid]);\n\n      // `winners` writes are CF-only since CRIT-3 (audit 2026-05-17).\n      // The `submitFoundCode` callable verifies caller-is-hunter +\n      // foundCode-matches inside a transaction before appending. No\n      // client-side update rule for `winners` exists anymore — any\n      // attempt to write the field directly is denied by default.\n\n      // Cancel-or-end: the creator (chicken) can flip `status` to\n      // `done` from any pre-done state — `waiting`, `readyToLaunch`,\n      // or `inProgress`. Covers pre-game cancel + mid-game cancel +\n      // the chicken's local \"natural game over\" detection (timer\n      // ran out, all hunters found). Every other status transition\n      // — start, launch — goes through Cloud Functions (admin SDK),\n      // so a hunter can't write `status: 'inProgress'` to bypass the\n      // LAUNCH gate and a stray client can't resurrect a finished\n      // game. Power-up activation is on `activatePowerUp`.\n      allow update: if request.auth != null\n                    && request.auth.uid == resource.data.creatorId\n                    && request.resource.data.diff(resource.data).affectedKeys()\n                        .hasOnly(['status'])\n                    && resource.data.status in ['waiting', 'readyToLaunch', 'inProgress']\n                    && request.resource.data.status == 'done';\n\n      // GameMaster (or the creator as a fallback when no GM has joined\n      // yet) re-designates the chicken before the game starts. Single\n      // field, `status == waiting` only — once the game is `inProgress`\n      // or `done`, the role is frozen. Used by the \"Désigner la poule\"\n      // screen (PP-26). hunterIds may be edited in the same write so the\n      // newly-designated hunter can be removed from the hunter pool.\n      allow update: if request.auth != null\n                    && resource.data.status == 'waiting'\n                    && (request.auth.uid == resource.data.creatorId\n                        || request.auth.uid in resource.data.get('gameMasterIds', []))\n                    && request.resource.data.diff(resource.data).affectedKeys()\n                        .hasOnly(['chickenId', 'hunterIds'])\n                    && request.resource.data.chickenId is string\n                    && request.resource.data.chickenId.size() > 0\n                    && !request.resource.data.hunterIds.hasAny([request.resource.data.chickenId]);\n\n      // Creator-only settings edit, frozen once the game starts.\n      // `gameMasterIds` mutates only via `joinAsGameMaster`; `chickenId`\n      // goes through the dedicated rule above; `winners` is callable-only;\n      // `status` goes through the cancel-only rule above (every other\n      // transition is server-scheduled).\n      allow update: if request.auth != null\n                    && resource.data.creatorId == request.auth.uid\n                    && resource.data.status in ['waiting', 'readyToLaunch']\n                    && !request.resource.data.diff(resource.data).affectedKeys()\n                        .hasAny(['gameMasterIds', 'chickenId', 'winners', 'status']);\n\n      // Only the creator can delete, and only while still in `waiting`.\n      allow delete: if request.auth != null\n                    && resource.data.creatorId == request.auth.uid\n                    && resource.data.status == 'waiting';\n\n      // Private namespace for fields a client must never read or write.\n      // Currently used by `joinAsGameMaster` (PP-70) to store the\n      // GameMaster password. Admin SDK bypasses these rules.\n      match /private/{docId} {\n        allow read, write: if false;\n      }\n\n      // Player positions (chickenLocations / hunterLocations) and chicken\n      // presence moved to Realtime Database (PP-102). Their access control\n      // lives in `database.rules.json`, gated by the `/games/{gameId}/meta`\n      // membership mirror written by the `mirrorGameMetaToRtdb` function.\n\n      // Registrations subcollection. PP-90 dropped the in-app\n      // registration-required gate, but the subcollection is still\n      // written: each in-app hunter creates a doc keyed by their UID\n      // so the GameMaster can pick a chicken from the team-name list\n      // (PP-86). PP-52 will reuse this subcollection for external\n      // Typeform/Stripe registrations using a random `registrationId`\n      // instead of `userId`.\n      match /registrations/{visitorId} {\n        // Readable by the registration owner, the chicken creator,\n        // any GameMaster on the game, and any hunter in the game. The\n        // GM needs every doc so the validator carte can label markers\n        // + the \"Désigner la poule\" drawer (PP-86) can list candidates.\n        // Hunters need every doc so the challenges leaderboard can show\n        // team names for everyone (replacing the old `/users` nickname\n        // fetch, which was a permissions hole for cross-hunter reads).\n        allow read: if request.auth != null\n                    && (visitorId == request.auth.uid\n                        || get(/databases/$(database)/documents/games/$(gameId)).data.creatorId == request.auth.uid\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));\n        allow create: if request.auth != null\n                      && visitorId == request.auth.uid\n                      && request.resource.data.userId == request.auth.uid\n                      && request.resource.data.keys().hasAll(['userId', 'teamName', 'joinedAt'])\n                      && request.resource.data.teamName is string\n                      && request.resource.data.teamName.size() > 0;\n        allow update: if request.auth != null\n                      && visitorId == request.auth.uid\n                      && request.resource.data.userId == request.auth.uid;\n        allow delete: if false;\n      }\n\n      match /challengeCompletions/{hunterId} {\n        allow read: if request.auth != null\n                    && (request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                        || request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));\n        allow create, update, delete: if false;\n      }\n\n      // PP-103: denormalized leaderboard read-model (`aggregates/leaderboard`).\n      // Written exclusively by `validateChallengeSubmission` /\n      // `applyOutOfZonePenalty` (admin SDK); read by everyone with a role on\n      // the game so clients read one doc instead of the whole\n      // challengeCompletions collection.\n      match /aggregates/{docId} {\n        allow read: if request.auth != null\n                    && (request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                        || request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));\n        allow write: if false;\n      }\n\n      // Per-game snapshot of the challenges catalog. Written exclusively\n      // by `onGameCreated` (admin SDK); read by everyone with a role on\n      // the game.\n      match /challenges/{challengeId} {\n        allow read: if request.auth != null\n                    && (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));\n        allow write: if false;\n      }\n\n      match /challengeSubmissions/{submissionId} {\n        allow read: if request.auth != null\n                    && (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));\n        allow create: if request.auth != null\n                      && request.auth.uid == request.resource.data.hunterId\n                      && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                      && request.time.toMillis()\n                           < get(/databases/$(database)/documents/games/$(gameId)).data.timing.end.toMillis()\n                      && request.resource.data.keys().hasAll(['challengeId', 'hunterId', 'type', 'submittedAt', 'mediaUrl', 'mediaType', 'status'])\n                      && request.resource.data.status == 'pending'\n                      && request.resource.data.type in ['oneShot', 'repeatable']\n                      && request.resource.data.mediaType in ['image', 'video']\n                      && request.resource.data.mediaUrl is string\n                      && request.resource.data.mediaUrl.size() > 0\n                      && request.resource.data.challengeId is string\n                      && request.resource.data.challengeId.size() > 0;\n        allow update, delete: if false;\n      }\n\n      // Power-ups subcollection\n      match /powerUps/{powerUpId} {\n        allow read: if request.auth != null\n                    && (request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.creatorId\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.hunterIds\n                        || request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.get('gameMasterIds', []));\n        // Power-ups are spawned exclusively by the `spawnPowerUpBatch` /\n        // `onGameCreated` Cloud Functions (admin SDK bypasses rules). Clients\n        // never create power-ups — prevents anti-cheat gaps and drift between\n        // chicken app state and Firestore.\n        allow create: if false;\n        // Collection only: set collectedBy + collectedAt by the collector.\n        // Activation goes through the `activatePowerUp` callable so the\n        // duration is server-authoritative.\n        allow update: if request.auth != null\n                      && request.resource.data.diff(resource.data).affectedKeys()\n                          .hasOnly(['collectedBy', 'collectedAt'])\n                      && request.resource.data.collectedBy == request.auth.uid\n                      && resource.data.get('collectedBy', null) == null;\n        allow delete: if false;\n      }\n    }\n\n    // User profiles (nickname, FCM token, platform) — each user can only read/write their own document.\n    match /users/{userId} {\n      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;\n    }\n\n    // Admin-only template. Cloud Functions read it via admin SDK and\n    // snapshot it into `/games/{gameId}/challenges` at game creation.\n    // Clients never touch this collection at runtime.\n    match /challenges/{challengeId} {\n      allow read, write: if false;\n    }\n\n    // GameMaster rate-limit counters (PP-70). One doc per\n    // `{userId}_{gameId}` key, written exclusively by the\n    // `joinAsGameMaster` Cloud Function via admin SDK. Clients can\n    // neither read (no probing the lock) nor write (no resetting their\n    // own counter).\n    match /gmRateLimits/{docId} {\n      allow read, write: if false;\n    }\n\n    // Validation-code rate-limit counters (XPLAT-M6, store-audit 2026-05-18).\n    // One doc per UID, written exclusively by `validateRegistrationCode` /\n    // `lookupGameByValidationCode` (admin SDK). Same lock-down as\n    // `gmRateLimits` — clients can't probe the lock or reset their counter.\n    match /validationRateLimits/{uid} {\n      allow read, write: if false;\n    }\n\n    // Account deletion requests (AND-H6, store-audit 2026-05-18). Captured\n    // from the public `pouleparty.be/delete-account` form by the\n    // `processAccountDeletion` Cloud Function (admin SDK). Carries the\n    // user-provided email + nickname + reason. Reads / writes are denied\n    // to all clients so the queue stays private — Julien processes from\n    // the Firebase console / admin tooling.\n    match /accountDeletionRequests/{rid} {\n      allow read, write: if false;\n    }\n\n    // Event registrations (PP-52) — pre-paid registrations created from the\n    // public web form before any in-app Game exists. Top-level collection\n    // (deliberately separate from the per-game `/games/{gameId}/registrations`\n    // subcollection used by PP-90/PP-86 for in-app teamName + chicken\n    // designation). Each doc carries a `batchId` field; the admin-mode wizard\n    // sets `Game.registrationBatchId` to the same value to link a game to\n    // its batch.\n    //\n    // Writes are admin-SDK only: `createPendingRegistration` writes the doc\n    // with `paid: false`, the Stripe webhook `confirmRegistrationPayment`\n    // flips `paid: true` (both bypass these rules via admin SDK).\n    //\n    // CRIT-1 (audit 2026-05-17): reads are now FULLY locked. Previously\n    // `allow read: if request.auth != null` relied on the 36^6 entropy of\n    // the 6-char code as the only gate, but the rule allowed enumerating\n    // the entire collection — leaking email / phone / playerName / teamName\n    // for every paying user (GDPR breach). Client lookups now go through\n    // the `validateRegistrationCode` + `lookupGameByValidationCode`\n    // callable Cloud Functions, which return only the minimum the JoinFlow\n    // needs (a boolean or `{type, gameId, batchId}`) — never PII.\n    match /eventRegistrations/{registrationId} {\n      allow read, create, update, delete: if false;\n    }\n\n    // Player reports — created by authenticated users from the in-app \"Report player\"\n    // button on leaderboards. Reads and mutations are admin-SDK-only so reporters can't\n    // see each other's reports and reportees can't delete reports about them.\n    match /reports/{reportId} {\n      allow create: if request.auth != null\n                    && request.resource.data.reporterId == request.auth.uid\n                    && request.resource.data.reportedUserId is string\n                    && request.resource.data.reportedUserId.size() > 0\n                    && request.resource.data.reportedUserId != request.auth.uid\n                    && request.resource.data.keys().hasAll(['reporterId', 'reportedUserId', 'reportedNickname', 'gameId', 'createdAt']);\n      allow read, update, delete: if false;\n    }\n\n    // Deny access to everything else\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-30T14:02:22.611583Z","metadata":{"services":["cloud.firestore"]}}
